@rendermode InteractiveServer
@inject pcm_planner.Data.RosterService RosterService

@if (summary is not null)
{
    <span class="text-muted small me-3">Season @summary.Season</span>
    <span class="text-muted small me-3">@summary.RaceCount races</span>
    <span class="text-muted small me-3">@summary.RiderCount riders</span>
    <span class="text-muted small">avg @summary.AvgRaceDays.ToString("F1") race days</span>
}

@code {
    private pcm_planner.Data.SeasonSummary? summary;

    protected override async Task OnInitializedAsync()
    {
        summary = await RosterService.GetSeasonSummaryAsync();
    }
}
